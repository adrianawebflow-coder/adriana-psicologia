---
---
<header class="nav">
  <div class="nav-inner">
    <a class="brand" href="/" aria-label="Adriana Psicología">
      <span class="brand-name">Adriana</span>
      <span class="brand-sub">PSICOLOGÍA</span>
    </a>

    <nav class="nav-menu" aria-label="Principal">
      <a href="/" class="active">Inicio</a>
      <a href="/sobre-mi">Sobre mí</a>
      <a href="/servicios">Servicios</a>
      <a href="/precio">Precio</a>
      <a href="/blog">Blog</a>
    </nav>

    <div class="nav-cta">
      <a class="btn-cta" href="https://calendly.com/adrianapsicologia/15-20min" target="_blank" rel="noopener">
        Contáctame
      </a>
    </div>

    <button class="burger" aria-label="Abrir menú" id="navBurger">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="sheet" id="navSheet" aria-hidden="true">
  <div class="sheet-panel">
    <button class="sheet-close" id="navSheetClose" aria-label="Cerrar menú">×</button>
    <a href="/">Inicio</a>
    <a href="/sobre-mi">Sobre mí</a>
    <a href="/servicios">Servicios</a>
    <a href="/precio">Precio</a>
    <a href="/blog">Blog</a>
    <a href="https://calendly.com/adrianapsicologia/15-20min" target="_blank" rel="noopener" class="sheet-cta">
      Contáctame
    </a>
  </div>
</div>

<style>
.nav {
  background: var(--color-bg-base);
  border-bottom: 1px solid rgba(0,0,0,.04);
  position: sticky;
  top: 0;
  z-index: 30;
}

.nav-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 14px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}

.brand {
  display: flex;
  flex-direction: column;
  line-height: 1;
  text-decoration: none;
  color: var(--color-text-primary);
}
.brand-name {
  font-family: var(--font-script);
  font-size: 34px;
  font-weight: 600;
  letter-spacing: -0.01em;
}
.brand-sub {
  font-family: var(--font-sans);
  font-size: 9px;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  margin-top: -2px;
  padding-left: 4px;
}

.nav-menu {
  display: none;
  gap: 32px;
  align-items: center;
}
.nav-menu a {
  font-family: var(--font-sans);
  font-size: 15px;
  font-weight: 500;
  color: var(--color-text-primary);
  text-decoration: none;
  transition: color 150ms ease;
}
.nav-menu a:hover,
.nav-menu a.active {
  color: var(--color-moss);
}

.nav-cta { display: none; }

.btn-cta {
  display: inline-flex;
  align-items: center;
  height: 42px;
  padding: 0 22px;
  background: var(--color-moss);
  color: var(--color-text-inverse);
  font-family: var(--font-sans);
  font-size: 14px;
  font-weight: 600;
  border-radius: var(--radius-full);
  text-decoration: none;
  transition: background var(--transition-fast), transform var(--transition-fast);
}
.btn-cta:hover {
  background: var(--color-moss-hover);
  transform: translateY(-1px);
}

.burger {
  width: 36px;
  height: 36px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  align-items: flex-end;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}
.burger span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--color-text-primary);
  border-radius: 2px;
}

@media (min-width: 880px) {
  .nav-menu,
  .nav-cta { display: flex; }
  .burger   { display: none; }
}

/* ── Mobile sheet ── */
.sheet {
  position: fixed;
  inset: 0;
  background: rgba(26,33,24,.55);
  display: none;
  z-index: 50;
}
.sheet.open { display: block; }

.sheet-panel {
  position: absolute;
  top: 0; right: 0;
  height: 100%;
  width: min(82vw, 320px);
  background: var(--color-bg-base);
  color: var(--color-text-primary);
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  box-shadow: -12px 0 32px rgba(0,0,0,.2);
}
.sheet-panel a {
  padding: 14px 4px;
  font-family: var(--font-sans);
  font-size: 16px;
  font-weight: 500;
  color: var(--color-text-primary);
  text-decoration: none;
  border-bottom: 1px solid var(--color-bg-border);
}
.sheet-panel a:hover { color: var(--color-moss); }

.sheet-cta {
  margin-top: 16px;
  text-align: center;
  background: var(--color-moss);
  color: var(--color-text-inverse) !important;
  border-radius: var(--radius-full);
  border-bottom: none !important;
}

.sheet-close {
  align-self: flex-end;
  width: 32px;
  height: 32px;
  display: grid;
  place-items: center;
  font-size: 22px;
  color: var(--color-text-primary);
  background: none;
  border: none;
  cursor: pointer;
  margin-bottom: 8px;
}
</style>

<script>
  const burger     = document.getElementById('navBurger');
  const sheet      = document.getElementById('navSheet');
  const sheetClose = document.getElementById('navSheetClose');
  const open  = () => { sheet?.classList.add('open');    sheet?.setAttribute('aria-hidden','false'); };
  const close = () => { sheet?.classList.remove('open'); sheet?.setAttribute('aria-hidden','true');  };
  burger?.addEventListener('click', open);
  sheetClose?.addEventListener('click', close);
  sheet?.addEventListener('click', (e) => { if (e.target === sheet) close(); });
  sheet?.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
</script>
