---
---
<section class="hero">
  <div class="hero-grid">

    <div class="hero-text">
      <h1 transition:name="hero-title">Psicóloga en Madrid. Un espacio para entender lo que te pasa</h1>
      <p class="lead">
        No necesitas tenerlo todo claro para empezar.
        Solo sentir que algo no va bien.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href="https://calendly.com/adrianapsicologia/15-20min" target="_blank" rel="noopener">
          Reservar primera sesión
        </a>
        <a class="btn btn-secondary" href="#sobre">Conocer a Adriana</a>
      </div>
    </div>

    <div class="hero-photo" role="img" aria-label="Adriana Esteban Labelle, psicóloga en Madrid"></div>

  </div>
</section>

<style>
/* ── Hero layout ── */
.hero {
  background: var(--color-bg-base);
}

.hero-grid {
  display: grid;
  grid-template-columns: 1fr;
  align-items: stretch;
}

.hero-text {
  padding: var(--section-pad-y) var(--gutter);
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
  justify-content: center;
}

h1 {
  font-family: var(--font-serif);
  font-weight: var(--fw-semi);
  font-size: clamp(1.875rem, 5vw, 3rem);
  line-height: 1.1;
  color: var(--color-text-primary);
  letter-spacing: -0.01em;
  max-width: 18ch;
  margin: 0;
}

.lead {
  font-family: var(--font-sans);
  font-size: var(--fs-body-lg);
  line-height: 1.55;
  color: var(--color-text-secondary);
  max-width: 42ch;
  margin: 0;
}

.cta-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 44px;
  padding: 0 22px;
  border-radius: var(--radius-full);
  font-family: var(--font-sans);
  font-size: var(--fs-body-sm);
  font-weight: var(--fw-semi);
  text-decoration: none;
  white-space: nowrap;
  transition: transform 120ms ease, filter 120ms ease, background var(--transition-fast);
}
.btn:hover { transform: translateY(-1px); filter: brightness(1.05); }

.btn-primary  { background: var(--color-moss); color: var(--color-text-inverse); }
.btn-primary:hover  { background: var(--color-moss-hover); filter: none; }
.btn-secondary { background: var(--color-clay); color: var(--color-text-inverse); }

/* ── Hero photo ── */
.hero-photo {
  width: 100%;
  aspect-ratio: 5 / 4;
  background: var(--color-bg-muted) center / cover no-repeat;
  background-image: url('/images/hero-adriana.png');
}

@media (min-width: 880px) {
  .hero-grid {
    grid-template-columns: 1fr 1fr;
    min-height: 580px;
  }
  .hero-text {
    padding: var(--section-pad-y) var(--gutter) var(--section-pad-y)
      max(var(--gutter), calc((100vw - 1280px) / 2 + var(--gutter)));
  }
  h1 {
    max-width: 14ch;
  }
  .hero-photo {
    aspect-ratio: auto;
    height: 100%;
    min-height: 580px;
  }
}
</style>
