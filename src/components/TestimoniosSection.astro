---
const testimonios = [
  {
    texto: "Adri lleva siendo mi psicóloga muchos años. Es una gran profesional que te ayuda con todo lo que necesitas y está atenta de ti siempre que la necesites. Muchas gracias por cuidarme tan bien.",
    autor: "L. García",
  },
  {
    texto: "Después de mucho tiempo dudando, dar el paso fue la mejor decisión. Adriana crea un espacio seguro donde puedes ser completamente honesta contigo misma.",
    autor: "M. Rodríguez",
  },
];

const testimonioActivo = testimonios[0];
---

<section class="testimonios">
  <span class="blob" aria-hidden="true"></span>
  <span class="blob b2" aria-hidden="true"></span>

  <div class="container">
    <h2 class="section-title reveal">Lo que dicen mis pacientes</h2>

    <div class="testi-stack reveal">
      <blockquote class="testi">
        <p>{testimonioActivo.texto}</p>
        <cite>— {testimonioActivo.autor}</cite>
      </blockquote>
    </div>

    <div class="testi-more reveal">
      <a href="https://g.page/r/" target="_blank" rel="noopener">Leer más reseñas →</a>
    </div>
  </div>
</section>

<style>
.testimonios {
  position: relative;
  background: var(--color-bg-soft);
  padding-top: var(--section-pad-top);
  padding-bottom: calc(var(--section-pad-bottom) + var(--space-4));
  overflow: hidden;
}

/* ── Blob decorativo ── */
.blob {
  position: absolute;
  pointer-events: none;
  border-radius: 50%;
  background: radial-gradient(closest-side, rgba(200,217,194,.7), transparent 70%);
  width: 520px;
  height: 520px;
  top: -120px;
  right: -120px;
  opacity: .55;
}
.blob.b2 {
  left: -160px;
  top: auto;
  bottom: -180px;
  right: auto;
  background: radial-gradient(closest-side, rgba(180,210,170,.5), transparent 70%);
}

.container {
  position: relative;
  z-index: 1;
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 var(--gutter);
}

.section-title {
  font-family: var(--font-serif);
  font-size: var(--fs-h2);
  font-weight: var(--fw-semi);
  color: var(--color-text-primary);
  letter-spacing: var(--ls-tight);
  margin: 0 0 var(--space-8);
  text-align: center;
}

/* ── Stacked card ── */
.testi-stack {
  position: relative;
  max-width: 520px;
  margin: 0 auto;
  padding: var(--space-6) var(--space-4) var(--space-4);
}

.testi {
  position: relative;
  background: var(--color-bg-base);
  border: 1px solid var(--color-moss);
  border-radius: 18px;
  padding: var(--space-6);
  color: var(--color-text-primary);
  margin: 0;
}

.testi::before,
.testi::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 18px;
  border: 1px solid var(--color-moss);
  background: var(--color-bg-base);
  z-index: -1;
}
.testi::before {
  transform: rotate(-2.5deg) translate(-6px, 4px);
}
.testi::after {
  transform: rotate(2deg) translate(8px, 8px);
  opacity: .85;
}

.testi p {
  font-family: var(--font-sans);
  font-size: var(--fs-body);
  line-height: var(--lh-body);
  color: var(--color-text-primary);
  font-weight: var(--fw-medium);
  margin: 0 0 var(--space-4);
}

.testi cite {
  display: block;
  font-style: normal;
  font-family: var(--font-sans);
  font-size: var(--fs-body-sm);
  font-weight: var(--fw-medium);
  color: var(--color-text-secondary);
}

.testi-more {
  display: flex;
  justify-content: center;
  margin-top: var(--space-8);
}
.testi-more a {
  font-family: var(--font-sans);
  font-size: var(--fs-body-sm);
  font-weight: var(--fw-medium);
  color: var(--color-text-secondary);
  text-decoration: underline;
  text-underline-offset: 4px;
  transition: color var(--transition-fast);
}
.testi-more a:hover { color: var(--color-moss); }

@media (min-width: 880px) {
  .testimonios {
    padding-top: var(--section-pad-top);
    padding-bottom: var(--section-pad-bottom);
  }
}
</style>
