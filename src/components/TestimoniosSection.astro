---
const testimonios = [
  {
    texto: "Adri lleva siendo mi psicóloga muchos años. Es una gran profesional que te ayuda con todo lo que necesitas y está atenta de ti siempre que la necesites. Muchas gracias por cuidarme tan bien.",
    autor: "L. García",
  },
  {
    texto: "Después de mucho tiempo dudando, dar el paso fue la mejor decisión. Adriana crea un espacio seguro donde puedes ser completamente honesta contigo misma.",
    autor: "M. Rodríguez",
  },
];
---

<section class="testimonios">
  <div class="container">
    <p class="eyebrow">Lo que dicen mis pacientes</p>
    <div class="testi-grid">
      {testimonios.map((t) => (
        <blockquote class="testi">
          <p>{t.texto}</p>
          <cite>— {t.autor}</cite>
        </blockquote>
      ))}
    </div>
    <div class="testi-more">
      <a href="https://g.page/r/" target="_blank" rel="noopener">Leer más reseñas →</a>
    </div>
  </div>
</section>

<style>
.testimonios {
  background: var(--color-bg-soft);
  padding: var(--section-pad-y) 0;
}

.container {
  max-width: 1080px;
  margin: 0 auto;
  padding: 0 var(--gutter);
}

.eyebrow {
  font-family: var(--font-sans);
  font-size: var(--fs-label);
  font-weight: var(--fw-semi);
  color: var(--color-text-muted);
  letter-spacing: var(--ls-wider);
  text-transform: uppercase;
  margin: 0 0 var(--space-6);
}

.testi-grid {
  display: grid;
  gap: var(--space-4);
  grid-template-columns: 1fr;
}

.testi {
  background: var(--color-bg-base);
  border: 1px solid var(--color-moss);
  border-radius: var(--radius-lg);
  padding: var(--space-6);
  margin: 0;
}

.testi p {
  font-family: var(--font-sans);
  font-size: var(--fs-body);
  line-height: var(--lh-body);
  color: var(--color-text-primary);
  font-weight: var(--fw-medium);
  margin: 0 0 var(--space-4);
}

.testi cite {
  display: block;
  font-style: normal;
  font-family: var(--font-sans);
  font-size: var(--fs-body-sm);
  font-weight: var(--fw-medium);
  color: var(--color-text-secondary);
}

.testi-more {
  display: flex;
  justify-content: center;
  margin-top: var(--space-6);
}

.testi-more a {
  font-family: var(--font-sans);
  font-size: var(--fs-body-sm);
  font-weight: var(--fw-medium);
  color: var(--color-text-secondary);
  text-decoration: none;
  padding: var(--space-2) 0;
  transition: color var(--transition-fast);
}
.testi-more a:hover {
  color: var(--color-moss);
  text-decoration: underline;
  text-underline-offset: 4px;
}

@media (min-width: 880px) {
  .testi-grid {
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }
}
</style>
