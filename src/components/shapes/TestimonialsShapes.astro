---
/**
 * TestimonialsShapes.astro
 * Formas abstractas para la sección de Testimonios (fondo oscuro bg-dark).
 * Uso: <TestimonialsShapes /> dentro de la sección testimonios, como primer hijo.
 *
 * La sección padre NECESITA fondo oscuro:
 *   position: relative;
 *   overflow: hidden;
 *   background: var(--color-bg-dark);
 */
---

<div class="testi-shapes" aria-hidden="true">
  <svg
    class="ts-svg"
    viewBox="0 0 900 500"
    preserveAspectRatio="xMidYMid slice"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Círculo grande: esquina sup-der, sangra fuera -->
    <circle
      class="ts-el ts-circle-lg"
      cx="900" cy="0" r="280"
      fill="#2E4628"
    />

    <!-- Blob inf-izq: musgo medio -->
    <path
      class="ts-el ts-blob-corner"
      d="M-30,430 C20,390 90,395 105,438 C120,481 88,515 45,518
         C2,521 -45,500 -55,462 C-65,424 -80,470 -30,430Z"
      fill="var(--color-moss, #3D5C35)"
    />

    <!-- Arco outline: centro-izquierda, en musgo claro -->
    <path
      class="ts-el ts-arc"
      d="M80,180 A110,110 0 0,1 300,180"
      fill="none"
      stroke="var(--color-moss-light, #8DBD84)"
      stroke-width="0.8"
    />

    <!-- Pill arcilla: flotando -->
    <rect
      class="ts-el ts-pill"
      x="380" y="420" width="100" height="16" rx="8"
      fill="var(--color-clay, #9C6B4E)"
    />

    <!-- Puntos degradados: esquina sup-izq -->
    <circle class="ts-el ts-dot-1" cx="80"  cy="60" r="3.5" fill="var(--color-moss-light, #8DBD84)"/>
    <circle class="ts-el ts-dot-2" cx="105" cy="60" r="3.5" fill="var(--color-moss-light, #8DBD84)"/>
    <circle class="ts-el ts-dot-3" cx="130" cy="60" r="3.5" fill="var(--color-moss-light, #8DBD84)"/>
    <circle class="ts-el ts-dot-4" cx="155" cy="60" r="3.5" fill="var(--color-moss-light, #8DBD84)"/>

    <!-- Círculo outline pequeño: centro-der -->
    <circle
      class="ts-el ts-circle-sm"
      cx="720" cy="300" r="55"
      fill="none"
      stroke="var(--color-moss-light, #8DBD84)"
      stroke-width="0.6"
    />

    <!-- Líneas paralelas horizontales: textura inf-der -->
    <line class="ts-el ts-hline-1" x1="580" y1="460" x2="900" y2="460"
          stroke="var(--color-moss-soft, #C8D9C2)" stroke-width="0.5"/>
    <line class="ts-el ts-hline-2" x1="640" y1="476" x2="900" y2="476"
          stroke="var(--color-moss-soft, #C8D9C2)" stroke-width="0.5"/>
    <line class="ts-el ts-hline-3" x1="700" y1="492" x2="900" y2="492"
          stroke="var(--color-moss-soft, #C8D9C2)" stroke-width="0.5"/>
  </svg>
</div>

<style>
  .testi-shapes {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .ts-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .ts-el { opacity: 0; }

  .ts-circle-lg {
    --final-opacity: 0.55;
    animation:
      ts-in 1200ms 60ms cubic-bezier(0.25, 0, 0, 1) forwards,
      float-circ 26s 1400ms ease-in-out infinite;
    transform-origin: 900px 0px;
  }

  .ts-blob-corner {
    --final-opacity: 0.45;
    animation: ts-in 1100ms 180ms cubic-bezier(0.25, 0, 0, 1) forwards;
  }

  .ts-arc {
    --final-opacity: 0.20;
    animation:
      ts-in 900ms 300ms cubic-bezier(0.25, 0, 0, 1) forwards,
      float-up 20s 1600ms ease-in-out infinite;
  }

  .ts-pill {
    --final-opacity: 0.18;
    animation:
      ts-in 900ms 420ms cubic-bezier(0.25, 0, 0, 1) forwards,
      float-up 24s 1800ms ease-in-out infinite reverse;
  }

  .ts-dot-1 { --final-opacity: 0.24; animation: ts-in 700ms 380ms cubic-bezier(0.25, 0, 0, 1) forwards; }
  .ts-dot-2 { --final-opacity: 0.17; animation: ts-in 700ms 420ms cubic-bezier(0.25, 0, 0, 1) forwards; }
  .ts-dot-3 { --final-opacity: 0.11; animation: ts-in 700ms 460ms cubic-bezier(0.25, 0, 0, 1) forwards; }
  .ts-dot-4 { --final-opacity: 0.06; animation: ts-in 700ms 500ms cubic-bezier(0.25, 0, 0, 1) forwards; }

  .ts-circle-sm {
    --final-opacity: 0.16;
    animation:
      ts-in 900ms 540ms cubic-bezier(0.25, 0, 0, 1) forwards,
      float-circ 30s 2000ms ease-in-out infinite;
    transform-origin: 720px 300px;
  }

  .ts-hline-1 { --final-opacity: 0.16; animation: ts-in 700ms 580ms cubic-bezier(0.25, 0, 0, 1) forwards; }
  .ts-hline-2 { --final-opacity: 0.10; animation: ts-in 700ms 620ms cubic-bezier(0.25, 0, 0, 1) forwards; }
  .ts-hline-3 { --final-opacity: 0.06; animation: ts-in 700ms 660ms cubic-bezier(0.25, 0, 0, 1) forwards; }

  @keyframes ts-in {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: var(--final-opacity, 0.15);
      transform: translateY(0);
    }
  }

  @keyframes float-up {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-10px); }
  }

  @keyframes float-circ {
    0%, 100% { transform: scale(1) translate(0, 0); }
    50%       { transform: scale(1.03) translate(-6px, -8px); }
  }

  /* ── Accesibilidad ── */
  @media (prefers-reduced-motion: reduce) {
    .ts-el {
      animation: none !important;
      opacity: var(--final-opacity, 0.15) !important;
      transform: none !important;
    }
  }
</style>
