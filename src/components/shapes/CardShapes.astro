---
/**
 * CardShapes.astro
 * Rectángulos redondeados inclinados para secciones de servicios y precio.
 * Uso: <CardShapes /> dentro de la sección, como primer hijo.
 *
 * La sección padre necesita:
 *   position: relative;
 *   overflow: hidden;
 *
 * Props:
 *   accent: 'moss' | 'clay' | 'stone'  (por defecto: 'moss')
 */

interface Props {
  accent?: 'moss' | 'clay' | 'stone';
}

const { accent = 'moss' } = Astro.props;
---

<div class="card-shapes" aria-hidden="true" data-accent={accent}>
  <div class="cs-shape cs-rect-lg"></div>
  <div class="cs-shape cs-rect-md"></div>
  <div class="cs-shape cs-pill"></div>
  <div class="cs-shape cs-rect-outline"></div>
</div>

<style>
  .card-shapes {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .cs-shape {
    position: absolute;
    opacity: 0;
    border-radius: var(--radius-lg, 8px);
  }

  /* ── Rect grande: esquina superior derecha ── */
  .cs-rect-lg {
    width: clamp(160px, 22vw, 300px);
    height: clamp(100px, 14vw, 190px);
    top: -40px;
    right: -50px;
    background: var(--color-bg-stone, #C8D9C2);
    border-radius: 24px;
    --r: -11deg;
    --final-opacity: 0.42;
    animation:
      rect-in 1000ms 100ms cubic-bezier(0.25, 0, 0, 1) forwards,
      float-rect 20s 1200ms ease-in-out infinite;
  }

  /* ── Rect mediano: esquina inferior izquierda ── */
  .cs-rect-md {
    width: clamp(100px, 14vw, 200px);
    height: clamp(65px, 9vw, 130px);
    bottom: -30px;
    left: -30px;
    background: var(--color-moss, #3D5C35);
    border-radius: 20px;
    --r: 9deg;
    --final-opacity: 0.09;
    animation:
      rect-in 1000ms 220ms cubic-bezier(0.25, 0, 0, 1) forwards,
      float-rect 24s 1400ms ease-in-out infinite reverse;
  }

  /* ── Pill horizontal: centro-bajo ── */
  .cs-pill {
    width: clamp(80px, 12vw, 160px);
    height: clamp(20px, 3vw, 32px);
    bottom: 22%;
    right: 12%;
    background: var(--color-clay, #9C6B4E);
    border-radius: var(--radius-full, 9999px);
    --final-opacity: 0.14;
    animation:
      pill-in 1000ms 340ms cubic-bezier(0.25, 0, 0, 1) forwards,
      float-pill 18s 1600ms ease-in-out infinite;
  }

  /* ── Rect outline: centro-izquierda ── */
  .cs-rect-outline {
    width: clamp(60px, 9vw, 120px);
    height: clamp(42px, 6vw, 80px);
    top: 30%;
    left: 6%;
    background: transparent;
    border: 1.5px solid var(--color-moss, #3D5C35);
    border-radius: 14px;
    --r: 7deg;
    --final-opacity: 0.22;
    animation:
      rect-in 1000ms 460ms cubic-bezier(0.25, 0, 0, 1) forwards,
      float-rect 26s 1800ms ease-in-out infinite;
  }

  /* ── Variantes de acento ── */
  [data-accent="clay"] .cs-rect-lg      { background: var(--color-clay-soft, #E8D5C8); }
  [data-accent="clay"] .cs-rect-md      { background: var(--color-clay, #9C6B4E); }
  [data-accent="clay"] .cs-pill         { background: var(--color-moss, #3D5C35); }
  [data-accent="clay"] .cs-rect-outline { border-color: var(--color-clay, #9C6B4E); }

  [data-accent="stone"] .cs-rect-lg     { background: var(--color-moss-soft, #C8D9C2); }
  [data-accent="stone"] .cs-rect-md     { background: var(--color-bg-border, #D4CFC0); }
  [data-accent="stone"] .cs-pill        { background: var(--color-bg-muted, #E2DDD1); }

  /* ── Keyframes ── */
  @keyframes rect-in {
    from {
      opacity: 0;
      transform: rotate(var(--r, 0deg)) translateY(20px);
    }
    to {
      opacity: var(--final-opacity, 0.15);
      transform: rotate(var(--r, 0deg)) translateY(0);
    }
  }

  @keyframes pill-in {
    from {
      opacity: 0;
      transform: rotate(-4deg) translateY(12px);
    }
    to {
      opacity: var(--final-opacity, 0.15);
      transform: rotate(-4deg) translateY(0);
    }
  }

  @keyframes float-rect {
    0%, 100% { transform: rotate(var(--r, 0deg)) translateY(0px); }
    50%       { transform: rotate(var(--r, 0deg)) translateY(-10px); }
  }

  @keyframes float-pill {
    0%, 100% { transform: rotate(-4deg) translateY(0px); }
    50%       { transform: rotate(-4deg) translateY(-7px); }
  }

  /* ── Accesibilidad ── */
  @media (prefers-reduced-motion: reduce) {
    .cs-shape {
      animation: none !important;
      opacity: var(--final-opacity, 0.15) !important;
      transform: rotate(var(--r, 0deg)) !important;
    }
  }
</style>
