---
/**
 * ProcessShapes.astro
 * Arcos SVG y líneas decorativas para la sección Cómo funciona / Proceso.
 * Uso: <ProcessShapes /> dentro de la sección proceso, como primer hijo.
 *
 * La sección padre necesita:
 *   position: relative;
 *   overflow: hidden;
 *   background: var(--color-bg-soft);
 */
---

<div class="process-shapes" aria-hidden="true">
  <svg
    class="ps-svg"
    viewBox="0 0 900 600"
    preserveAspectRatio="xMidYMid slice"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Arco grande: enmarca el contenido por la derecha -->
    <path
      class="ps-el ps-arc-lg"
      d="M820,50 A320,320 0 0,1 820,550"
      fill="none"
      stroke="var(--color-moss, #3D5C35)"
      stroke-width="1.2"
    />

    <!-- Arco mediano: izquierda, parcialmente visible -->
    <path
      class="ps-el ps-arc-md"
      d="M-10,150 A160,160 0 0,1 220,150"
      fill="none"
      stroke="var(--color-bg-border, #D4CFC0)"
      stroke-width="1.5"
    />

    <!-- Semicírculo relleno: sup-izq pequeño -->
    <path
      class="ps-el ps-semicircle"
      d="M60,0 A70,70 0 0,1 200,0"
      fill="var(--color-moss-soft, #C8D9C2)"
    />

    <!-- Líneas paralelas — textura esquina inf-der -->
    <line class="ps-el ps-line-1" x1="680" y1="450" x2="680" y2="600"
          stroke="var(--color-moss, #3D5C35)" stroke-width="0.8"/>
    <line class="ps-el ps-line-2" x1="698" y1="450" x2="698" y2="600"
          stroke="var(--color-moss, #3D5C35)" stroke-width="0.8"/>
    <line class="ps-el ps-line-3" x1="716" y1="450" x2="716" y2="600"
          stroke="var(--color-moss, #3D5C35)" stroke-width="0.8"/>
    <line class="ps-el ps-line-4" x1="734" y1="450" x2="734" y2="600"
          stroke="var(--color-moss, #3D5C35)" stroke-width="0.8"/>

    <!-- Puntos degradados: sup-der -->
    <circle class="ps-el ps-dot-1" cx="640" cy="80" r="4" fill="var(--color-moss, #3D5C35)"/>
    <circle class="ps-el ps-dot-2" cx="665" cy="80" r="4" fill="var(--color-moss, #3D5C35)"/>
    <circle class="ps-el ps-dot-3" cx="690" cy="80" r="4" fill="var(--color-moss, #3D5C35)"/>
    <circle class="ps-el ps-dot-4" cx="715" cy="80" r="4" fill="var(--color-moss, #3D5C35)"/>

    <!-- Línea ondulada: separador inferior -->
    <path
      class="ps-el ps-wave"
      d="M100,570 C150,556 180,584 230,570 C280,556 310,584 360,570
         C410,556 440,584 490,570 C540,556 570,584 620,570"
      fill="none"
      stroke="var(--color-bg-border, #D4CFC0)"
      stroke-width="1.2"
    />

    <!-- Pill relleno pequeño: flota en centro -->
    <rect class="ps-el ps-pill"
          x="350" y="30" width="120" height="22" rx="11"
          fill="var(--color-clay-soft, #E8D5C8)"/>
  </svg>
</div>

<style>
  .process-shapes {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .ps-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .ps-el { opacity: 0; }

  .ps-arc-lg {
    --final-opacity: 0.16;
    animation:
      ps-in 1100ms 80ms cubic-bezier(0.25, 0, 0, 1) forwards,
      float-arc 22s 1300ms ease-in-out infinite;
  }

  .ps-arc-md {
    --final-opacity: 0.30;
    animation: ps-in 1100ms 180ms cubic-bezier(0.25, 0, 0, 1) forwards;
  }

  .ps-semicircle {
    --final-opacity: 0.45;
    animation:
      ps-in 1000ms 260ms cubic-bezier(0.25, 0, 0, 1) forwards,
      float-arc 18s 1500ms ease-in-out infinite reverse;
  }

  .ps-line-1 { --final-opacity: 0.18; animation: ps-in 800ms 320ms cubic-bezier(0.25, 0, 0, 1) forwards; }
  .ps-line-2 { --final-opacity: 0.12; animation: ps-in 800ms 380ms cubic-bezier(0.25, 0, 0, 1) forwards; }
  .ps-line-3 { --final-opacity: 0.08; animation: ps-in 800ms 440ms cubic-bezier(0.25, 0, 0, 1) forwards; }
  .ps-line-4 { --final-opacity: 0.04; animation: ps-in 800ms 500ms cubic-bezier(0.25, 0, 0, 1) forwards; }

  .ps-dot-1 { --final-opacity: 0.28; animation: ps-in 700ms 360ms cubic-bezier(0.25, 0, 0, 1) forwards; }
  .ps-dot-2 { --final-opacity: 0.20; animation: ps-in 700ms 410ms cubic-bezier(0.25, 0, 0, 1) forwards; }
  .ps-dot-3 { --final-opacity: 0.13; animation: ps-in 700ms 460ms cubic-bezier(0.25, 0, 0, 1) forwards; }
  .ps-dot-4 { --final-opacity: 0.07; animation: ps-in 700ms 510ms cubic-bezier(0.25, 0, 0, 1) forwards; }

  .ps-wave {
    --final-opacity: 0.35;
    animation: ps-in 1000ms 560ms cubic-bezier(0.25, 0, 0, 1) forwards;
  }

  .ps-pill {
    --final-opacity: 0.40;
    animation:
      ps-in 900ms 640ms cubic-bezier(0.25, 0, 0, 1) forwards,
      float-arc 20s 1800ms ease-in-out infinite;
  }

  @keyframes ps-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: var(--final-opacity, 0.15);
      transform: translateY(0);
    }
  }

  @keyframes float-arc {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-10px); }
  }

  /* ── Accesibilidad ── */
  @media (prefers-reduced-motion: reduce) {
    .ps-el {
      animation: none !important;
      opacity: var(--final-opacity, 0.15) !important;
      transform: none !important;
    }
  }
</style>
